# Shared across frontend and backend — copy to frontend/.env and backend/.env as needed

# --- Database ---
DATABASE_URL=postgres://timetracker:timetracker@localhost:5432/timetracker?sslmode=disable

# --- NextAuth (frontend) ---
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- API (frontend → backend) ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Email (frontend) ---
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@example.com

# --- Go API (backend) ---
JWT_SECRET=your-jwt-secret-here   # must match NEXTAUTH_SECRET
PORT=8080
